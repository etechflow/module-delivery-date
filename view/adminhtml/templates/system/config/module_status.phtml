<?php
/**
 * Module Status banner — top of the admin config page.
 *
 * @var \ETechFlow\DeliveryDate\Block\Adminhtml\System\Config\Form\ModuleStatus $block
 * @var \Magento\Framework\Escaper $escaper
 */

$status = $block->getStatus();

$bg = match ($status['level']) {
    'active'   => '#e8f5e9',
    'disabled' => '#f5f5f5',
    'warning'  => '#fff3e0',
    'info'     => '#e3f2fd',
    default    => '#f5f5f5',
};
$border = match ($status['level']) {
    'active'   => '#43a047',
    'disabled' => '#9e9e9e',
    'warning'  => '#fb8c00',
    'info'     => '#1e88e5',
    default    => '#9e9e9e',
};
$titleColor = match ($status['level']) {
    'active'   => '#2e7d32',
    'disabled' => '#616161',
    'warning'  => '#ef6c00',
    'info'     => '#1565c0',
    default    => '#424242',
};
?>
<div style="display:flex; gap:14px; align-items:flex-start; padding:14px 18px;
            margin:8px 0 16px; border-radius:6px; border-left:4px solid <?= $escaper->escapeHtmlAttr($border) ?>;
            background:<?= $escaper->escapeHtmlAttr($bg) ?>;">
    <div style="font-size:22px; line-height:1; flex-shrink:0;">
        <?= $escaper->escapeHtml($status['icon']) ?>
    </div>
    <div style="flex:1; min-width:0;">
        <strong style="display:block; color:<?= $escaper->escapeHtmlAttr($titleColor) ?>;
                       font-size:15px; margin-bottom:4px;">
            <?= $escaper->escapeHtml($status['title']) ?>
        </strong>
        <div style="color:#424242; font-size:13px; line-height:1.5;">
            <?= $escaper->escapeHtml($status['body']) ?>
        </div>
    </div>
</div>