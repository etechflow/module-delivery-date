<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="400">
            <label>eTechFlow</label>
        </tab>
        <section id="etechflow_deliverydate"
                 translate="label"
                 type="text"
                 sortOrder="140"
                 showInDefault="1"
                 showInWebsite="1"
                 showInStore="1">
            <label>Delivery Date</label>
            <tab>etechflow</tab>
            <resource>ETechFlow_DeliveryDate::config</resource>

            <group id="module_status" translate="label" type="text" sortOrder="1"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Module Status</label>
                <frontend_model>ETechFlow\DeliveryDate\Block\Adminhtml\System\Config\Form\ModuleStatus</frontend_model>
            </group>

            <!-- ============================================================
                 LICENSE
            ============================================================ -->
            <group id="license" translate="label" type="text" sortOrder="5"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>
                <field id="license_key" translate="label comment" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <comment><![CDATA[Paste your eTechFlow SP-XXXX subscription key. Generated automatically after Stripe payment. Bundle key also accepted. Get one at <a href="https://etechflow.com" target="_blank">etechflow.com</a>]]></comment>
                </field>
                <field id="issued_key" translate="label comment" type="obscure" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Issued Key (auto)</label>
                    <comment><![CDATA[Set automatically on first successful validation. Used to restore the key after an IP-block event. Do not edit.]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="portal_url" translate="label comment" type="text" sortOrder="25"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[eTechFlow licensing portal endpoint. Update if your portal URL changes.]]></comment>
                </field>
                <field id="bundle_license_key" translate="label comment" type="obscure" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Bundle License Key</label>
                    <comment><![CDATA[Shared key that activates every eTechFlow module on this host. Set EITHER this OR the per-module key above.]]></comment>
                    <config_path>etechflow_bundle/license/license_key</config_path>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>

            <!-- ============================================================
                 PAYMENT (STRIPE)
            ============================================================ -->

            <!-- ============================================================
                 GENERAL SETTINGS
            ============================================================ -->
            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Master switch. Yes — render the date picker at checkout. No — module silently does nothing.]]></comment>
                </field>
                <field id="disable_delivery_on" translate="label comment" type="multiselect" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Disable Delivery On</label>
                    <source_model>ETechFlow\DeliveryDate\Model\Source\Weekday</source_model>
                    <can_be_empty>1</can_be_empty>
                    <comment><![CDATA[Weekdays the customer can NOT pick. Defaults to Sun + Sat.]]></comment>
                </field>
                <field id="minimal_delivery_interval" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Minimum Days to Delivery</label>
                    <validate>validate-not-negative-number validate-digits</validate>
                    <comment><![CDATA[Days between order placement and earliest pickable delivery day. 0 = same-day; 1 = tomorrow.]]></comment>
                </field>
                <field id="maximal_delivery_interval" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Maximum Days Ahead Customer Can Pick</label>
                    <validate>validate-greater-than-zero validate-digits</validate>
                    <comment><![CDATA[How many days into the future the calendar shows. Default 14.]]></comment>
                </field>
                <field id="exclude_blocked_from_intervals" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Count "Minimum Days" in working days only</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="same_day_cutoff_enabled" translate="label comment" type="select" sortOrder="60"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Same-day cutoff time</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="same_day_cutoff_time" translate="label comment" type="text" sortOrder="70"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Same-day cutoff (HH:MM, 24h)</label>
                    <depends><field id="same_day_cutoff_enabled">1</field></depends>
                </field>
                <field id="next_day_cutoff_enabled" translate="label comment" type="select" sortOrder="80"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Next-day cutoff time</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="next_day_cutoff_time" translate="label comment" type="text" sortOrder="90"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Next-day cutoff (HH:MM, 24h)</label>
                    <depends><field id="next_day_cutoff_enabled">1</field></depends>
                </field>
                <field id="delivery_comment" translate="label comment" type="textarea" sortOrder="100"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Helpful note to show next to the date picker</label>
                </field>
                <field id="delivery_comment_style" translate="label comment" type="select" sortOrder="110"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Note style</label>
                    <source_model>ETechFlow\DeliveryDate\Model\Source\CommentStyle</source_model>
                    <depends><field id="delivery_comment">1</field></depends>
                </field>
            </group>

            <!-- ============================================================
                 DELIVERY DATE — field-level config
            ============================================================ -->
            <group id="delivery_date" translate="label" type="text" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Date Field Behaviour</label>
                <field id="is_required" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Required at checkout</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="set_default_value" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Preselect a day for the customer</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="default_value_offset" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Preselected day offset</label>
                    <validate>validate-not-negative-number validate-digits</validate>
                    <depends><field id="set_default_value">1</field></depends>
                </field>
                <field id="field_note" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Field label / instruction</label>
                </field>
            </group>

            <group id="quota" translate="label" type="text" sortOrder="30"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Daily Delivery Quota (v0.9)</label>
                <field id="daily_limit" translate="label comment" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Maximum deliveries per day</label>
                    <validate>validate-greater-than-zero validate-number</validate>
                    <comment><![CDATA[Cap customer-pickable deliveries per day. 0 = unlimited.]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>