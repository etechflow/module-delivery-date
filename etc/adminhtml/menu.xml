<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Backend:etc/menu.xsd">
    <menu>
        <!-- eTechFlow::root is injected at runtime by this module's own
             Plugin/Adminhtml/EnsureEtechflowMenu (idempotent), so the module is
             fully independent and never declares the shared id in XML. A second
             XML declaration of that id would fatal the merged admin menu
             (uniqueAddItemId), so only own-namespace ids are declared here. -->

        <!-- Delivery Date column. -->
        <add id="ETechFlow_DeliveryDate::management"
             title="Delivery Date"
             module="ETechFlow_DeliveryDate"
             sortOrder="20"
             parent="eTechFlow::root"
             resource="ETechFlow_DeliveryDate::management"/>

        <add id="ETechFlow_DeliveryDate::time_interval"
             title="Time Intervals"
             module="ETechFlow_DeliveryDate"
             sortOrder="10"
             parent="ETechFlow_DeliveryDate::management"
             action="etechflow_dd/timeInterval/index"
             resource="ETechFlow_DeliveryDate::time_interval"/>

        <add id="ETechFlow_DeliveryDate::exception_day"
             title="Exception Days"
             module="ETechFlow_DeliveryDate"
             sortOrder="20"
             parent="ETechFlow_DeliveryDate::management"
             action="etechflow_dd/exceptionDay/index"
             resource="ETechFlow_DeliveryDate::exception_day"/>

        <!-- Previously the shared id eTechFlow::configuration; moved into this
             module's own namespace so this module declares no shared eTechFlow node. -->
        <add id="ETechFlow_DeliveryDate::configuration"
             title="Configuration"
             module="ETechFlow_DeliveryDate"
             sortOrder="30"
             parent="ETechFlow_DeliveryDate::management"
             action="adminhtml/system_config/edit/section/etechflow_deliverydate"
             resource="Magento_Config::config"/>
    </menu>
</config>